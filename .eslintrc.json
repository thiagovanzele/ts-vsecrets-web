{
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": [
    "prettier",
    "eslint:recommended",
    "plugin:react/recommended",
    "plugin:import/recommended",
    "plugin:@typescript-eslint/recommended"
  ],
  "parser": "@typescript-eslint/parser",
  "ignorePatterns": ["**/*.js", "*.js"],
  "parserOptions": {
    "ecmaFeatures": {
      "jsx": true
    },
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "plugins": [
    "react",
    "import",
    "prettier",
    "react-hooks",
    "@typescript-eslint",
    "eslint-plugin-import-helpers"
  ],
  "rules": {
    "no-console": "warn",
    "prettier/prettier": "error",
    "max-len": [
      "warn",
      {
        "code": 100,
        "tabWidth": 2,
        "ignoreUrls": true,
        "ignoreStrings": true,
        "ignoreComments": true,
        "ignoreTemplateLiterals": true
      }
    ],
    "arrow-body-style": "off",
    "prefer-destructuring": "off",
    "prefer-arrow-callback": "off",
    "array-callback-return": "off",
    "import/named": "off",
    "no-nested-ternary": "warn",
    "import/no-extraneous-dependencies": "off",
    "import/prefer-default-export": "off",
    "react/prop-types": "off",
    "react/button-has-type": "warn",
    "react/require-default-props": "off",
    "react/jsx-props-no-spreading": "off",
    "react-hooks/rules-of-hooks": "error",
    "react-hooks/exhaustive-deps": "warn",
    "react/react-in-jsx-scope": "off",
    "react/jsx-key": "error",
    "no-shadow": "off",
    "no-param-reassign": "off",
    "no-restricted-imports": ["warn", "date-fns, date-fns/locale"],
    "no-use-before-define": "off",
    "@typescript-eslint/no-shadow": "error",
    "@typescript-eslint/explicit-function-return-type": "error",
    "@typescript-eslint/no-non-null-assertion": "off",
    "@typescript-eslint/no-use-before-define": ["error", { "functions": false }],
    "@typescript-eslint/no-unused-vars": "error",
    "@typescript-eslint/no-var-requires": "off",
    "@typescript-eslint/consistent-type-definitions": "off",
    "react/jsx-filename-extension": [
      "error",
      {
        "extensions": [".tsx"]
      }
    ],
    "import/extensions": [
      "error",
      "ignorePackages",
      {
        "ts": "never",
        "tsx": "never"
      }
    ],
    "no-mixed-spaces-and-tabs": "off",
    "semi": ["error", "always"],
    "import-helpers/order-imports": [
      "error",
      {
        "newlinesBetween": "always",
        "groups": [
          "/^react/",
          "/^styled-components/",
          "module",
          "/^@wof/utilities-belt/",
          "/^src/",
          ["parent", "index", "sibling"],
          "/^./styles/"
        ],
        "alphabetize": {
          "order": "asc",
          "ignoreCase": true
        }
      }
    ]
  },
  "settings": {
    "import/resolver": {
      "typescript": {
        "project": [
          "packages/wiseoffices/tsconfig.json",
          "packages/qrcode/tsconfig.json",
          "packages/taburetto/tsconfig.json",
          "packages/utilities-belt/tsconfig.json"
        ]
      }
    }
  }
}
